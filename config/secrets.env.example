# config/secrets.env.example — ŞABLON (Faz 5, F5A-8)
#
# Gerçek dosya: `config/secrets.env` — .gitignore'da, ASLA commitlenmez.
# Kurulum (kullanıcı ELLE yapar; değerleri sohbete/koda YAZMAYIN):
#   1) cp config/secrets.env.example config/secrets.env
#   2) Aşağıdaki değerleri kendi bilgilerinizle doldurun.
#   3) chmod 600 config/secrets.env   (yalnız sahibi okur/yazar)
#
# Kod bu değerleri yalnızca çalışma anında okur; log/journal/Telegram çıktılarına
# journal.masking ile MASKELİ yazar (düz metin sızmaz). Session hash ayrıca
# runtime/algolab_session.json'a 600 izniyle yazılır (login sonrası, otomatik).

ALGOLAB_API_KEY=API-XXXXXXXX   # AlgoLab panelinden alınan "API-..." anahtarı
ALGOLAB_USERNAME=              # TC kimlik no veya Deniz müşteri no
ALGOLAB_PASSWORD=              # internet şubesi şifresi
TELEGRAM_TOKEN=               # BotFather bot token'ı (opsiyonel; telegram.enabled=false ise gerekmez)
TELEGRAM_CHAT_ID=             # izinli tek chat_id (komutlar yalnız buradan kabul edilir)
